# Option 1: API key (set this OR use credentials.json, not both)
ANTHROPIC_API_KEY=your-api-key-here

# Option 2: Place a credentials.json file in the project root.
# If present, it takes priority over ANTHROPIC_API_KEY.

# mitmproxy web UI password (default: mitmpass)
# MITMPROXY_WEB_PASSWORD=mitmpass

# API key for authenticating calls to the local API server
# For `docker compose --profile api up`
# When set, calls to http://localhost:4000/v1/messages need to send the key in x-api-key header
# Set base URL and api key in whatever service is calling the API server:
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=${API_SERVER_KEY}
# Uncomment this to require authentication:
# API_SERVER_KEY=your-random-local-password
